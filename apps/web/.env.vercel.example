# Environment variables для Vercel deployment.
# Скопировать в Vercel Dashboard → Project Settings → Environment Variables.
# Все NEXT_PUBLIC_* должны быть видны браузеру, остальные — server-only.

# === Обязательные ===

# URL staging API на fly.io (NEXT_PUBLIC — нужен и серверу и клиенту)
NEXT_PUBLIC_API_URL=https://pandaclock-api-staging.fly.dev/api/v1

# URL marketing landing page (для footer-ссылок в /login)
NEXT_PUBLIC_MARKETING_URL=https://pandaclock.uz

# === Опциональные (всё пустое = выключено) ===

# Sentry — error tracking; если есть DSN, ошибки идут в Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog — продуктовая аналитика
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
