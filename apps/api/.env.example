# Node
NODE_ENV="development"
PORT=4000

# Database
DATABASE_URL="postgresql://pandaclock:dev@localhost:5432/pandaclock?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="dev-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_REFRESH_TTL="30d"

# Email (через Mailpit локально)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@pandaclock.uz"

# Storage (через MinIO локально)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="pandaclock"
S3_SECRET_KEY="pandaclockdev"
S3_BUCKET="pandaclock-files"

# App URLs
APP_DOMAIN="pandaclock.uz"
APP_URL="http://localhost:3000"
MARKETING_URL="http://localhost:3001"

# Sentry
SENTRY_DSN=""

# Bcrypt cost
BCRYPT_ROUNDS=10
